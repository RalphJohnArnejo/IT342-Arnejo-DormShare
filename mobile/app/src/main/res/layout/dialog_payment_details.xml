<?xml version="1.0" encoding="utf-8"?>
<!-- Payment Details dialog — matches web Settlement.jsx payment modal.
     Shows paying to/amount header, Card Payment (Stripe) option, and Confirm button. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1a1a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💳"
                android:textSize="20sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Payment Details"
                android:textColor="#e2e8f0"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <!-- Paying To / Amount section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_chip_gray"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <!-- Paying to -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Paying to:"
                    android:textColor="#94a3b8"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvPayeeName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#c49a3c"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Amount -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Amount:"
                    android:textColor="#94a3b8"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvPaymentAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#e2e8f0"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Payment Method: Card Payment (Stripe) -->
        <LinearLayout
            android:id="@+id/optionStripe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_chip_gray"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <View
                android:id="@+id/radioStripe"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/bg_radio_selected" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💳"
                android:textSize="16sp"
                android:layout_marginStart="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Card Payment (Stripe)"
                android:textColor="#c49a3c"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Manual Settlement Option -->
        <LinearLayout
            android:id="@+id/optionManual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_chip_gray"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <View
                android:id="@+id/radioManual"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/bg_radio_unselected" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅"
                android:textSize="16sp"
                android:layout_marginStart="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mark as Settled (Manual)"
                android:textColor="#94a3b8"
                android:textSize="15sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Confirm Payment Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmPayment"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Confirm Payment"
            android:textColor="#1a1a2e"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#c49a3c"
            app:cornerRadius="12dp" />

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelPayment"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#94a3b8"
            android:layout_marginTop="4dp" />

    </LinearLayout>
</ScrollView>
