<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Description -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Description"
            app:boxStrokeColor="#c49a3c"
            app:hintTextColor="#c49a3c">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etExpenseDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Amount -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Amount (₱)"
            app:boxStrokeColor="#c49a3c"
            app:hintTextColor="#c49a3c">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etExpenseAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Category -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textSize="14sp"
            android:textColor="#94a3b8"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:padding="12dp"
            android:background="@drawable/bg_card_dark_rounded" />

        <!-- Split With -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Split With"
            android:textSize="14sp"
            android:textColor="#94a3b8"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupMembers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:singleSelection="false" />

        <!-- Split Preview -->
        <TextView
            android:id="@+id/tvSplitPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#c49a3c"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:padding="8dp"
            android:background="@drawable/bg_card_dark_rounded"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
