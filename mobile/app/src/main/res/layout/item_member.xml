<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Avatar Circle -->
    <FrameLayout
        android:layout_width="32dp"
        android:layout_height="32dp">

        <TextView
            android:id="@+id/tvMemberInitial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="R"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_chip_gray" />

    </FrameLayout>

    <!-- Member Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvMemberName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ralph John Arnejo"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvYouBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" (You)"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvMemberEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ralphjohnarnejo@gmail.com"
            android:textColor="@color/card_dark_text_light"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Crown for admin -->
    <TextView
        android:id="@+id/tvAdminCrown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
